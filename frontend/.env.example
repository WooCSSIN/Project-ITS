# ============================================
# ENVIRONMENT DETECTION
# ============================================
VITE_ENVIRONMENT=development

# ============================================
# API CONFIGURATION
# ============================================
VITE_API_HTTP_BASE=http://localhost:8000
VITE_API_WS_BASE=ws://localhost:8000
VITE_API_V1_PREFIX=/api/v1
VITE_API_V2_PREFIX=/api/v2
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000

# ============================================
# WEBSOCKET CONFIGURATION
# ============================================
VITE_WS_CHAT_PATH=/chatbot/ws/chat
VITE_WS_FRAMES_PATH=/road/ws/frames
VITE_WS_INFO_PATH=/road/ws/info
VITE_WS_CHART_PATH=/road/ws/chart
VITE_WS_RECONNECT_INTERVAL=3000
VITE_WS_MAX_RECONNECT_ATTEMPTS=5
VITE_WS_HEARTBEAT_INTERVAL=30000
VITE_WS_MAX_MESSAGE_SIZE=1048576

# ============================================
# AUTHENTICATION CONFIGURATION
# ============================================
VITE_AUTH_TOKEN_KEY=access_token
VITE_AUTH_REFRESH_TOKEN_KEY=refresh_token
VITE_AUTH_USER_KEY=user_info
VITE_AUTH_TOKEN_EXPIRE_DAYS=7
VITE_AUTH_AUTO_REFRESH=true
VITE_AUTH_REMEMBER_ME_DAYS=30

# ============================================
# UI CONFIGURATION
# ============================================
VITE_APP_NAME=Smart Transportation System
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Real-time Traffic Monitoring & AI Assistant
VITE_DEFAULT_THEME=light
VITE_ENABLE_THEME_TOGGLE=true
VITE_ENABLE_ANIMATIONS=true
VITE_ANIMATION_DURATION=300
VITE_SIDEBAR_WIDTH=256
VITE_HEADER_HEIGHT=64
VITE_DEFAULT_PAGE_SIZE=10

# ============================================
# CHAT CONFIGURATION
# ============================================
VITE_CHAT_DRAFT_KEY=chat_draft
VITE_CHAT_HISTORY_KEY=chat_history
VITE_CHAT_MAX_MESSAGE_LENGTH=2000
VITE_CHAT_MAX_HISTORY_SIZE=100
VITE_CHAT_ENABLE_IMAGE_UPLOAD=true
VITE_CHAT_ENABLE_FILE_UPLOAD=false
VITE_CHAT_ENABLE_MARKDOWN=true
VITE_CHAT_TYPING_TIMEOUT=3000

# ============================================
# TRAFFIC MONITORING CONFIGURATION
# ============================================
VITE_TRAFFIC_SHOW_BOXES=true
VITE_TRAFFIC_SHOW_SPEED=true
VITE_TRAFFIC_SHOW_COUNT=true
VITE_TRAFFIC_MAX_FPS=30
VITE_TRAFFIC_VIDEO_QUALITY=high

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
VITE_MAX_FILE_SIZE=52428800
VITE_MAX_IMAGE_SIZE=10485760
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
VITE_ALLOWED_VIDEO_TYPES=video/mp4,video/avi,video/mov
VITE_UPLOAD_CHUNK_SIZE=1048576

# ============================================
# NOTIFICATION CONFIGURATION
# ============================================
VITE_NOTIFICATION_POSITION=top-right
VITE_NOTIFICATION_SUCCESS_DURATION=3000
VITE_NOTIFICATION_ERROR_DURATION=5000
VITE_NOTIFICATION_INFO_DURATION=3000
VITE_NOTIFICATION_WARNING_DURATION=4000
VITE_NOTIFICATION_ENABLE_SOUND=false
VITE_NOTIFICATION_MAX_COUNT=5

# ============================================
# LOGGING CONFIGURATION
# ============================================
VITE_LOG_LEVEL=debug
VITE_ENABLE_CONSOLE_LOGS=true
VITE_ENABLE_ERROR_REPORTING=false
VITE_LOG_API_CALLS=true
VITE_LOG_WEBSOCKET_MESSAGES=true

# ============================================
# CACHE CONFIGURATION
# ============================================
VITE_ENABLE_API_CACHE=true
VITE_CACHE_DEFAULT_TTL=300000
VITE_CACHE_USER_INFO_TTL=1800000
VITE_CACHE_ROAD_INFO_TTL=600000
VITE_CACHE_MAX_SIZE=100

# ============================================
# FEATURE FLAGS
# ============================================
VITE_FEATURE_ANALYTICS=false
VITE_FEATURE_PWA=false
VITE_FEATURE_OFFLINE_MODE=false
VITE_FEATURE_PROFILE_EDIT=true
VITE_FEATURE_PASSWORD_CHANGE=true
VITE_FEATURE_THEME_CUSTOMIZATION=true
VITE_FEATURE_ADMIN_PANEL=true
VITE_FEATURE_SYSTEM_METRICS=true
