# API Gemini
GOOGLE_API_KEY=

# Database SQL configuration
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_db_password
DATABASE_PORT=5433
DATABASE_HOST=localhost
DATABASE_NAME=transportation_system

# JWT configuration
JWT_SECRET_KEY=your_jwt_secret_key
ACCESS_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# Telegram Bot Token (Bot Father)
BOT_TOKEN=your_telegram_bot_token

# Runtime flags
OPENCV_VIDEOIO_PRIORITY_MSMF=0
OPENCV_VIDEOIO_PRIORITY_DSHOW=1
KMP_DUPLICATE_LIB_OK=TRUE

# Redis and SQL logging
REDIS_URL=redis://localhost:6379/0
SQL_ECHO=false

# Application logging
LOG_LEVEL=INFO
LOG_FILE_NAME=app.log
LOG_FILE_MAX_BYTES=5242880
LOG_FILE_BACKUP_COUNT=5
LOG_TO_CONSOLE=false

# Chatbot memory
CHAT_MAX_SHORT_TERM_MESSAGES=24
CHAT_LONG_TERM_MEMORY_LIMIT=3
CHAT_MEMORY_DB_URI=postgresql://postgres:your_db_password@localhost:5433/transportation_system

# MinIO configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=your_minio_secret
ACCESS_KEY=admin
SECRET_KEY=your_minio_secret
MINIO_SECURE=false
MINIO_BUCKET=road-frames
MINIO_URL_EXPIRY_SECONDS=3600
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_PUBLIC_SCHEME=http
MINIO_IMAGE_URL_MODE=public
MINIO_AUTO_SET_PUBLIC_READ=true